# Reference only. The real values live in a Modal Secret named
# `cma-self-hosted-sandboxes-secrets` (see README), not on disk.
#
# This file documents the env-var contract so a future operator knows
# which keys the webhook + sandbox runner read at runtime.

# Bearer auth for the work poll/ack/stop and the runner's only credential.
# Anthropic gives this to you when you create the self-hosted environment.
ANTHROPIC_ENVIRONMENT_KEY=sk-ant-oat-...

# Self-hosted environment id (also from Anthropic).
ANTHROPIC_ENVIRONMENT_ID=env_01...

# Webhook signing secret. Anthropic issues this when you register the
# webhook URL. Use a placeholder before the first `modal deploy`, then
# update with the real `whsec_...` value via `modal secret create --force`.
ANTHROPIC_WEBHOOK_SECRET=whsec_...

# Optional: override the Anthropic API base. Default is fine in production.
# ANTHROPIC_BASE_URL=https://api.anthropic.com
